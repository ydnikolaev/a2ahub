# spec 25 §T5/§6 AC-2: `a2a feedback validate --ci <file>` is the intake gate.
# A schema+checks-green file at feedback/inbox/<id>.yaml whose filename == id
# passes (exit 0). Every guard class fails closed with its FB code + exit 1:
#   FB-008 path not under feedback/inbox/
#   FB-007 filename != id
#   FB-005 status != new
#   FB-003 a checks.* gate is false
#   FB-004 oversize (> 16 KiB)
# (FB-001/FB-002 schema classes are covered by feedback_new_validate.txtar and
# the schemas/feedback unit corpus.)

mkdir feedback/inbox

# happy path: correct location, filename == id, green
cp good.yaml feedback/inbox/fb-20260715-abc123.yaml
exec a2a feedback validate --ci feedback/inbox/fb-20260715-abc123.yaml
stdout 'valid'

# FB-008: a green file, but not under feedback/inbox/
! exec a2a feedback validate --ci good.yaml
stdout 'FB-008'

# FB-007: under feedback/inbox/ but the filename does not match the id
cp good.yaml feedback/inbox/not-the-id.yaml
! exec a2a feedback validate --ci feedback/inbox/not-the-id.yaml
stdout 'FB-007'

# FB-005: status is not `new`
cp accepted.yaml feedback/inbox/fb-20260715-def456.yaml
! exec a2a feedback validate --ci feedback/inbox/fb-20260715-def456.yaml
stdout 'FB-005'

# FB-003: one honesty gate is false
cp checksfalse.yaml feedback/inbox/fb-20260715-aaa111.yaml
! exec a2a feedback validate --ci feedback/inbox/fb-20260715-aaa111.yaml
stdout 'FB-003'

# FB-004: oversize — a green file at the right name/path, padded past 16 KiB
# with a trailing YAML comment (still parseable, just too big).
exec sh -c 'cp oversize-base.yaml feedback/inbox/fb-20260715-bbb222.yaml && { printf "\n# "; head -c 17000 /dev/zero | tr "\0" x; } >> feedback/inbox/fb-20260715-bbb222.yaml'
! exec a2a feedback validate --ci feedback/inbox/fb-20260715-bbb222.yaml
stdout 'FB-004'

-- good.yaml --
feedback: v1
id: fb-20260715-abc123
kind: docs
severity: minor
title: "reference page omits how threads close"
summary: "the authoring doc does not mention the close transition anywhere"
context:
  a2a_version: v0.1.1
  os_arch: darwin/arm64
  surface: docs
checks:
  docs_consulted: true
  grounded_in_real_work: true
  not_space_specific: true
  no_sensitive_content: true
  duplicates_checked: true
status: new

-- accepted.yaml --
feedback: v1
id: fb-20260715-def456
kind: docs
severity: minor
title: "status must be new at submit, this one is accepted"
summary: "resolution/status are hub-mutated fields, illegal at intake time"
context:
  a2a_version: v0.1.1
  os_arch: darwin/arm64
  surface: docs
checks:
  docs_consulted: true
  grounded_in_real_work: true
  not_space_specific: true
  no_sensitive_content: true
  duplicates_checked: true
status: accepted

-- checksfalse.yaml --
feedback: v1
id: fb-20260715-aaa111
kind: docs
severity: minor
title: "one honesty gate is still false, must refuse"
summary: "duplicates_checked is false, so the whole checks block is not green"
context:
  a2a_version: v0.1.1
  os_arch: darwin/arm64
  surface: docs
checks:
  docs_consulted: true
  grounded_in_real_work: true
  not_space_specific: true
  no_sensitive_content: true
  duplicates_checked: false
status: new

-- oversize-base.yaml --
feedback: v1
id: fb-20260715-bbb222
kind: docs
severity: minor
title: "green at the top, oversize once padded past sixteen kib"
summary: "the trailing comment pushes the whole-file byte count over the cap"
context:
  a2a_version: v0.1.1
  os_arch: darwin/arm64
  surface: docs
checks:
  docs_consulted: true
  grounded_in_real_work: true
  not_space_specific: true
  no_sensitive_content: true
  duplicates_checked: true
status: new
