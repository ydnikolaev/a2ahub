# OP-206 `a2a sync`: fetches every connected space's mirror — AC-301.3
# (offline/no-hub direct-git path): the fixture's remote is a local
# filesystem path, so this proves the git-fallback path needs no network.
# Idempotent: a second run is also a plain success (AC-301.1).
exec a2a sync
exec a2a sync
