{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "envelope/v1/question.schema.json",
  "title": "Envelope: question (v1)",
  "allOf": [{ "$ref": "base.schema.json" }],
  "type": "object",
  "properties": {
    "type": { "const": "question" },
    "id": { "pattern": "^XQ-" },
    "category": {
      "type": "string",
      "enum": ["clarification", "defect", "choice"]
    },
    "to": {
      "description": "Exchange type (X class, not decision): exactly one target system.",
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 1
    }
  },
  "required": ["category"],
  "patternProperties": { "^x_": true },
  "unevaluatedProperties": false
}
