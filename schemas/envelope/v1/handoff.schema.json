{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "envelope/v1/handoff.schema.json",
  "title": "Envelope: handoff (v1)",
  "description": "Fields per the-plan §16.2 exactly. No `category` field per §5.2.1 (dash entry, same as decision/response) — unevaluatedProperties:false rejects it structurally if present.",
  "allOf": [{ "$ref": "base.schema.json" }],
  "type": "object",
  "properties": {
    "type": { "const": "handoff" },
    "id": { "pattern": "^XH-" },
    "deliverables": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "ref": { "type": "string" },
          "kind": { "type": "string", "enum": ["code", "contract", "config", "doc", "data"] }
        },
        "required": ["name", "ref", "kind"],
        "additionalProperties": false
      }
    },
    "verification": { "type": "string" },
    "acceptance_criteria": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "limitations": { "type": "array", "items": { "type": "string" } },
    "env_requirements": { "type": "string" },
    "fulfills": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "to": {
      "description": "Exchange type (X class, not decision): exactly one target system.",
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "maxItems": 1
    }
  },
  "required": ["deliverables", "verification", "acceptance_criteria", "limitations", "fulfills"],
  "patternProperties": { "^x_": true },
  "unevaluatedProperties": false
}
