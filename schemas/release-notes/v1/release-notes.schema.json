{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "release-notes/v1/release-notes.schema.json",
  "title": "Release notes — releasenotes/<version>.yaml (v1)",
  "description": "The authored, version-keyed release-notes corpus (P31): one file per shipped a2a version, surfaced via `a2a whatsnew`. Each entry is a directive a2a informs on — the agent decides and runs it (scope: space is never run by a2a itself).",
  "type": "object",
  "properties": {
    "schema": { "const": "release-notes/v1" },
    "version": {
      "type": "string",
      "description": "Dotted major.minor.patch, matching this file's own name (e.g. 0.4.0.yaml -> \"0.4.0\").",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "released": { "type": "string", "format": "date" },
    "headline": { "type": "string" },
    "changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": ["feat", "fix", "break", "schema", "policy"]
          },
          "impact": {
            "type": "string",
            "enum": ["high", "normal", "low"]
          },
          "subject": { "type": "string" },
          "detail": { "type": "string" },
          "affects": {
            "type": "array",
            "items": { "type": "string" }
          },
          "action": {
            "type": "object",
            "properties": {
              "scope": {
                "type": "string",
                "enum": ["local", "space", "none"]
              },
              "why": { "type": "string" },
              "detect": {
                "type": "array",
                "items": { "type": "string" }
              },
              "run": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "required": ["scope", "why"],
            "additionalProperties": false
          }
        },
        "required": ["id", "kind", "impact", "subject", "detail", "action"],
        "additionalProperties": false
      }
    }
  },
  "required": ["schema", "version", "released", "headline", "changes"],
  "additionalProperties": false
}
