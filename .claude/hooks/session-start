#!/usr/bin/env bash
# mate_synced: v0.98.0
# mate session-start soft-nudge (spec §5d) — a CONSUMER-side hook, synced by the
# claude-code adapter. It compares the pulled release (.mate/lock.json) against
# the latest upstream tag and nudges when behind; if it also finds local drift
# vs the lock hashes, it prints the stronger "diverged" line. Fail-closed on the
# side of silence: any error (offline, no lock, no mate binary) → say nothing,
# never block a session.
#
# Wire in the consumer's .claude/settings.json:
#   "hooks": { "SessionStart": [ { "hooks": [ { "type": "command",
#     "command": ".claude/hooks/session-start" } ] } ] }
#
# NOTE: since v0.2.0 this is a drift-gated manifest artifact (kind: hook), not a
# hand-copied file. Its version-comparison logic is covered by scripts/e2e.sh.
# Registering it in settings.json (above) is still a manual settings step.
set -euo pipefail

ROOT="${CLAUDE_PROJECT_DIR:-.}"
LOCK="$ROOT/.mate/lock.json"
SSOT_REMOTE="${MATE_SSOT_REMOTE:-https://github.com/ydnikolaev/mate.git}"

[ -f "$LOCK" ] || exit 0   # not a mate consumer (or never pulled) — stay silent

release() { sed -n 's/.*"release"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$LOCK" | head -1; }
LOCKED="$(release)"
[ -n "$LOCKED" ] || exit 0

# Latest upstream tag (network-degradable; silent on failure).
LATEST="$(git ls-remote --tags --refs "$SSOT_REMOTE" 2>/dev/null \
  | sed -n 's#.*refs/tags/\(v[0-9][0-9.]*\)$#\1#p' | sort -V | tail -1 || true)"

# The CHANGELOG version headers newer than $LOCKED, quoted inline (spec §5d). This
# needs read access to the SSOT's CHANGELOG at $LATEST: if $MATE_SSOT_REMOTE is a
# local checkout, `git show` resolves it; against a bare URL it can't, so we fall
# back to a pointer line. Fail-quiet either way — the base nudge is never lost.
quote_changelog() {
  # `|| true` inside the sub: the git-show pipeline fails under `pipefail` on a
  # bare-URL remote (or a tag missing CHANGELOG.md) — swallow it here so `set -e`
  # never aborts the hook before its final `exit 0` (and the drift check below).
  local news
  news="$(git -C "$SSOT_REMOTE" show "$LATEST:CHANGELOG.md" 2>/dev/null \
    | awk -v locked="[$LOCKED]" '/^## \[v/ { if (index($0, locked)) exit; print }' || true)"
  if [ -n "$news" ]; then
    echo "  new since $LOCKED:"
    echo "$news" | sed 's/^## /    • /'
  else
    echo "  (see CHANGELOG for the lines since $LOCKED)"
  fi
}

# older A B → true when A is strictly older than B (semver order).
older() { [ "$1" != "$2" ] && [ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -1)" = "$2" ]; }

# The ARTIFACT release the tip carries (manifest source.release @ LATEST). This is
# the axis a `pull` moves; it lags the tag on a binary-only release. Reading it
# needs the SAME local-checkout remote as quote_changelog — empty against a bare
# URL, which drops us to the honest both-actions hedge below.
artifact_release() {
  git -C "$SSOT_REMOTE" show "$LATEST:harness/manifest.yaml" 2>/dev/null \
    | sed -n 's/.*release:[[:space:]]*\(v[0-9][0-9.]*\).*/\1/p' | head -1
}

# The installed binary's release (robust, local). Used ONLY to silence the
# reinstall line once the operator has actually reinstalled — so a binary-only
# release nudges until acted on, then goes quiet (never nags forever).
installed_release() {
  command -v mate >/dev/null 2>&1 || return 0
  mate --version 2>/dev/null | sed -n 's/.*\(v[0-9][0-9.]*\).*/\1/p' | head -1
}

if [ -n "$LATEST" ] && older "$LOCKED" "$LATEST"; then
  # `|| true`: under `set -euo pipefail` a bare `X="$(cmd)"` whose command-sub
  # fails (git-show against a bare-URL remote, or a tag whose tree lacks the
  # manifest) would EXIT the script here — before any nudge prints. Guard both so
  # the empty-value branches (hedge / can't-confirm) actually run.
  ART="$(artifact_release || true)"
  if [ -n "$ART" ] && older "$LOCKED" "$ART"; then
    # Artifacts genuinely advanced → pull brings new content.
    echo "mate: harness behind — locked $LOCKED, artifacts now $ART. Run \`mate pull\`."
    quote_changelog
  elif [ -n "$ART" ]; then
    # Tag advanced but the artifact axis is current ($ART == $LOCKED): a binary-only
    # release (engine/CLI hardening). A pull would only re-stamp — the fix is a
    # binary reinstall. Stay quiet once the binary is already current.
    INST="$(installed_release || true)"
    if [ -z "$INST" ] || older "$INST" "$LATEST"; then
      echo "mate: CLI behind — artifacts ($LOCKED) are current, but the binary advanced to $LATEST (engine-only release)."
      echo "  reinstall from the $LATEST checkout: \`go install ./cmd/mate\` (a pull would only re-stamp)."
      quote_changelog
    fi
  else
    # Bare-URL remote: can't read the artifact axis to tell pull from reinstall.
    # Name both actions honestly rather than guess (never a wrong single action).
    echo "mate: harness behind — locked $LOCKED, upstream $LATEST. Run \`mate pull\` (or reinstall the CLI if this was an engine-only release)."
    quote_changelog
  fi
fi

# Stronger signal: local tampering vs the lock hashes.
if command -v mate >/dev/null 2>&1 && ! mate status --root "$ROOT" >/dev/null 2>&1; then
  echo "mate: local harness diverged from the lock — reconcile (\`mate pull\`) or promote the change upstream."
fi

exit 0
